{
  "name": "@tinyforged/signature-kit-react",
  "version": "1.1.1",
  "description": "React electronic signature component",
  "license": "MIT",
  "author": "TinyForged",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tinyforged/signature-kit": "^1.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "react",
    "signature",
    "canvas",
    "component"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TinyForged/signature-kit",
    "directory": "packages/react"
  }
}
