{
  "name": "@tinyforged/signature-kit",
  "version": "1.1.1",
  "description": "Framework-agnostic electronic signature core with undo, watermark, and resize support",
  "license": "MIT",
  "author": "TinyForged",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "signature_pad": "^5.1.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "signature",
    "canvas",
    "handwriting",
    "draw",
    "bezier"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TinyForged/signature-kit",
    "directory": "packages/core"
  }
}
